# ─── ZIMONZA Daily Stock Update — Environment Variables ───────────────────────
# Copy this file to .env and fill in your Firebase credentials.
# These values are found in: Firebase Console → Project Settings → Your Apps

FIREBASE_API_KEY=YOUR_API_KEY_HERE
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID
FIREBASE_APP_ID=YOUR_APP_ID

# NOTE: For this static HTML app, paste the above values directly into
#       js/firebase-config.js — no build step required.
